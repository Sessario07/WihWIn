aws_region          = "ap-northeast-1"
project_name        = "wihwin"
environment         = "prod"
instance_type       = "c6g.xlarge"
ssh_allowed_cidr    = "0.0.0.0/0"
ssh_public_key_path = "~/.ssh/wihwin-key.pub"
budget_limit_amount = "30"
budget_alert_email  = "your-email@example.com"
github_repo_url     = "https://github.com/your-org/WihWIn.git"
github_branch       = "main"
